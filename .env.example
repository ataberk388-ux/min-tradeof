# Bu dosyayi '.env' olarak kopyalayin ve gercek degerleri girin.
#   cp .env.example .env
# .env dosyasi .gitignore'da — ASLA commit etmeyin.

# PostgreSQL
POSTGRES_DB=cryptoalarm
POSTGRES_USER=cryptoalarm
POSTGRES_PASSWORD=guclu_sifre_gir

# Backend datasource (opsiyonel — verilmezse POSTGRES_* ile localhost varsayilir)
# DATABASE_URL=jdbc:postgresql://localhost:5432/cryptoalarm

# JWT imzalama anahtari — HS256 icin >= 32 karakter rastgele string
#   ornek: openssl rand -hex 32
JWT_SECRET=en-az-32-karakterlik-rastgele-gizli-anahtar
